PORT=3000
BASE_URL=https://ai.laodog.top
# Optional. Use this for server-to-server API calls when the container cannot
# reach BASE_URL reliably through Cloudflare. Example: http://host.docker.internal:8080
UPSTREAM_BASE_URL=
# Optional. Set this when UPSTREAM_BASE_URL points to an IP/internal host but the
# upstream service needs the public Host value.
UPSTREAM_HOST_HEADER=ai.laodog.top
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-me
RECORDS_ACCESS_KEY=replace-with-a-long-secret
DB_DRIVER=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=laodog_bonus
DB_USERNAME=laodog_bonus
DB_PASSWORD=replace-me
DB_CHARSET=utf8mb4
LOG_FILE=/var/www/html/data/app.log
CLAIM_AMOUNT=10
CLAIM_NOTES=Self-service bonus claim
RATE_LIMIT_MAX=20
CAPTCHA_TTL_SECONDS=300
CAPTCHA_MAX_ATTEMPTS=5
CAPTCHA_RATE_LIMIT_MAX=40
GALLERY_UPLOAD_MAX_FILES=8
GALLERY_UPLOAD_MAX_BYTES=3145728
